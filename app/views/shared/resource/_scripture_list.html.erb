<% resource.sermon_scriptures.each_with_index do |sermon_scripture, i| %>
  <% if i>0 && resource.sermon_scriptures[i-1].scripture.name == sermon_scripture.scripture.name %>
    , <%= link_to sermon_scripture.range, scripture_path(sermon_scripture.scripture_id) %>
  <% else %>
    <%= link_to sermon_scripture.name, scripture_path(sermon_scripture.scripture_id) %>
  <% end %>
<% end %>